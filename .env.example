# Waveloom 配置
#
# 两种配置方式：
#   1. settings.json — 全部 LLM 参数（含 api_key），推荐
#   2. 环境变量 — 作为备用，settings.json 中为空的字段会回退到环境变量
#
# --- API Key（二选一）---
# settings.json 中的 api_key 优先；此处作为回退
# LLM_API_KEY=sk-your-api-key

# --- 以下环境变量作为 settings.json 的备用回退，一般不直接使用 ---
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o
# LLM_PROVIDER=openai
